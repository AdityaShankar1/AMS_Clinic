# Copy this file to .env and fill in your values before running the app.

# Supabase / PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres

# Phase 1 role keys — change ALL THREE to strong random secrets before deploying.
# Which key you send in the X-Staff-Key header determines your role.
DOCTOR_KEY=doctor-secret-change-this
RECEPTIONIST_KEY=recep-secret-change-this
PATIENT_KEY=patient-secret-change-this

# Demo patient account for the MVP UI flow.
DEMO_PATIENT_ID=1
